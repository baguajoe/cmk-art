# ----------------------------------------------------------------------------
# Frontend environment variables (Vite)
# ----------------------------------------------------------------------------
# Copy this file to ".env" (in this /client folder) and fill in the value.
# Vite only exposes variables that start with VITE_ to the browser.
#
#   cp .env.example .env
#
# After changing .env, restart `npm run dev` for the change to take effect.
# ----------------------------------------------------------------------------

# Your Stripe PUBLISHABLE key (starts with pk_test_... in test mode, pk_live_...
# in live mode). This is safe to expose in the browser. It is provided here for
# future use (e.g. Stripe.js / Elements); the current checkout flow redirects to
# Stripe's hosted page using a URL created by the backend, so the app works even
# if this is left unset.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# NOTE: The CashApp / Venmo / Zelle handles are NOT env vars — set them in
# src/data/paymentHandles.js.
