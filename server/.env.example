# ----------------------------------------------------------------------------
# Backend environment variables (Flask)
# ----------------------------------------------------------------------------
# Copy this file to ".env" (in this /server folder) and fill in each value.
# The .env file is git-ignored — never commit real secrets.
#
#   cp .env.example .env
# ----------------------------------------------------------------------------

# ---- Stripe -----------------------------------------------------------------
# From the Stripe Dashboard → Developers → API keys. Use the TEST keys
# (sk_test_... / pk_test_...) while developing; swap to live keys to go live.
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# The publishable key is used by the FRONTEND (client/.env → VITE_STRIPE_PUBLISHABLE_KEY).
# It's listed here only for reference; the backend does not need it.
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Webhook signing secret (whsec_...). Get it from the Stripe CLI
# (`stripe listen --forward-to localhost:5000/api/stripe-webhook`) for local
# testing, or from Dashboard → Developers → Webhooks in production.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# ---- Email (order notifications via Gmail SMTP) -----------------------------
# EMAIL_ADDRESS      the Gmail address you send FROM.
# EMAIL_APP_PASSWORD a Gmail *App Password* (16 chars, no spaces) — NOT your
#                    normal Gmail password. Enable 2-Step Verification, then
#                    create one at https://myaccount.google.com/apppasswords
# EMAIL_TO           where order notifications are sent (usually your own email).
EMAIL_ADDRESS=youraddress@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_TO=youraddress@gmail.com

# ---- Optional ---------------------------------------------------------------
# Port the Flask server listens on (default 5000).
# PORT=5000
# Public URL of the frontend, used for Stripe success/cancel redirects. In dev
# this is auto-detected from the request Origin, so you can leave it unset.
# FRONTEND_URL=https://your-live-site.example

# NOTE: The CashApp / Venmo / Zelle handles are NOT set here — they live in the
# frontend at client/src/data/paymentHandles.js.
